{% comment %} Renders standard card object structure without any wrappers {% endcomment %}
{%- if product != blank -%}
  {%
    render 'card-product',
    card_product: product,
    media_aspect_ratio: 'square',
    show_secondary_image: true,
    show_vendor: true,
    show_sku: true,
    quick_add: 'standard',
    show_stock: true,
    pickup_availability_components: 'headline';
  %}
{%- endif -%}
