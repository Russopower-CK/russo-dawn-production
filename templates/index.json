        "heading_LhgFaF": {
          "type": "heading",
          "settings": {
            "heading": "<strong>More Power, More Problems?</strong>",
            "heading_size": "h2"
          }
        },
        "text_rPRMVQ": {
          "type": "text",
          "settings": {
            "text": "<p>Two-cycle equipment has long been favored for its high power-to-weight ratio. Found in chainsaws, leaf blowers, and trimmers, these machines deliver impressive performance in a compact design. However, that extra power comes with a trade-off—increased maintenance needs.</p>",
            "text_style": "body"
          }
        },
