    "russo_testimonial_4GEURr": {
      "type": "russo-testimonial",
      "blocks": {
        "review_NDAnD3": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Highly recommended — by far one of the best small engine equipment stores I’ve experienced.Ryan and Justin both provided outstanding customer service and took the time to help me narrow down my options, ultimately helping me find the best package deal for my needs. Crissy was very helpful as well.Donavan was also extremely helpful, getting some of my equipment in quickly for service and taking the time to educate me on proper self-maintenance between service visits.Thank you all for the professionalism, knowledge, and excellent customer experience. You definitely did not disappoint.",
            "author": "Conner Cuts - 5/28/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_JbtRwt": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Another great experience shopping and working with Russo Power Equipment. Their staff is also incredibly friendly and make sure my team and I get in and out quickly.Big shout out to Matt, Jeff and Edgar for keeping things moving smoothly and making sure we get what we need to continue growing.Johnny is also always a great help with information on equipment and making sure we get equipment back up and running our alternative options provided.DDR Outdoor Services wouldn’t be able to do what we do with out you guys!",
            "author": "Danny Rodriguez - 5/25/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_VtV38M": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Excellent place to do business.  My Toro lawn mower was a good choice.  Service after the sale was top notch AND they support our Veterans!",
            "author": "R Michael Flynn - 5/13/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_EtpcJr": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Always a pleasure to shop there for lawn equipment and turf supplies. Lots of choices and friendly staff. Parts, service or new equipment Russo is a great choice!",
            "author": "Daniel Silverman - 3/25/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_376hm6": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Always a pleasure to shop there for lawn equipment and turf supplies. Lots of choices and friendly staff. Parts, service or new equipment Russo is a great choice!",
            "author": "Daniel Silverman - 3/25/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_nHHYXE": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Had a very positive experience getting a tractor with Aaron. he is versed in their product line and knows a lot about kioti tractors. he was super easy to work with. If you're looking for a new kioti tractors their prices are very \"competitive\". I did a lot of looking everywhere online and was very pleased to find the best deal I could find was 5 miles away from home.",
            "author": "James T Miller - 3/21/26",
            "location": "Mooresville, IN",
            "location_url": "shopify://pages/storelocator"
          }
        },
        "review_Wpx6FT": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "We have been using Russo for the many years they have been in Elgin and throughout all that time no one has been better at their job than Jose Muneton at always getting us what we need in a quick, efficient, professional, and most importantly, respectful manner. His social media clips really highlight that commitment to the customer.",
            "author": "Crown Tree Care - 3/18/26",
            "location": "Elgin, IL",
            "location_url": "shopify://pages/storelocator"
          }
        },
        "review_HqGYHG": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "I just bought a zero turn from here, everyone i was dealing with was very nice. Luis did a great job. He had answers for all my questions and if he didnt have an answer.. he got one for me! The time I was waiting for my paperwork, I saw so many customers come in and they got great service just like I did! 10/5 starts!",
            "author": "Chris Bilek - 3/13/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_JxgNrX": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Best dealer in the area I travel from Angola Indiana to Fort Wayne to purchase new echo and redmax equipment this summer I should buy two commercial Scag mowers from Russos highly recommended them!",
            "author": "Adan Sanchez - 3/9/26",
            "location": "Fort Wayne",
            "location_url": "https://russopower.com/a/store-locator/fort-wayne-in"
          }
        },
        "review_6PMWix": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Best place to buy Landscaping equipment, landscaping tools and replacement parts in the area. Highly recommended!",
            "author": "Mr Aguilar - 2/12/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_nbmWje": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Very good people to know and be around with helpful courteous, professional down to earth people vary professional at every aspect.",
            "author": "John Bukur - 2/7/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_WM8rRX": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Purchased Toro Electric Snowblower & Mower Great service, would highly recommend!",
            "author": "Lynn Lee - 1/31/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_aQAq9L": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "I bought a large Toro snow thrower 4 years ago, pre-Russo. A weird thing happened - one of the tires had deflated in the cold and came off the rim! Russo said we can remount it. 7 min later it was done. I asked, \"what do I owe you?\" A: \"Nothing, you're good\". WOW! Old time customer satisfaction. Little acts like that build customer loyalty. Thanks!",
            "author": "Gary VanMoffaert - 1/29/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_eqBTTy": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "I went for a load of salt. Inside staff were very friendly and helpful. Ordering and paying for salt was quick and easy.",
            "author": "Damian Rosenbaum - 1/29/26",
            "location": "",
            "location_url": ""
          }
        },
        "review_Ld6JzD": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review": "Been coming here since they opened the location. Sales staff are very good people who will go above and beyond to help customers. Forklift drivers work very hard and will do anything they can to help load product. Wouldn’t go anywhere else for salt / parts.",
            "author": "Brendon Austin - 1/28/26",
