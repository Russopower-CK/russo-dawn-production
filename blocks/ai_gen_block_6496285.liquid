{% doc %}
  @prompt
    one row of 4 svg icons with title and text under it, with hyperlink, make the background color changeable for the container, instead of it specifically having to be an svg can it be custom liquid snippet or html, The titles should share the same text color property
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
      .ai-icon-row-{{ ai_gen_id }} {
        display: block;
        width: {{ block.settings.desktop_width_percent }}%;
        max-width: none;
        margin-top: 1px;
      }

  .ai-icon-row-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.gap }}px;

    max-width: var(--page-width);
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
  }


      .ai-icon-item-{{ ai_gen_id }} {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        text-decoration: none;
      }
    .ai-icon-row-wrapper-{{ai_gen_id }}{

      background: {{ block.settings.background_color }};
    }
      .ai-icon-wrapper-{{ ai_gen_id }} {
        width: {{ block.settings.icon_size }}px;
        height: {{ block.settings.icon_size }}px;
        margin-bottom: {{ block.settings.icon_spacing }}px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: {{ block.settings.icon_color }};
      }

      .ai-icon-wrapper-{{ ai_gen_id }} svg {
        width: 100%;
        height: 100%;
        fill: {{ block.settings.icon_color }};
        stroke: {{ block.settings.icon_color }};
      }

      .ai-icon-wrapper-{{ ai_gen_id }} img {
        transition: none;
        filter: {{ block.settings.image_filter | default: 'none' }};
      }

      .ai-icon-item-{{ ai_gen_id }}:hover .ai-icon-wrapper-{{ ai_gen_id }} {
        color: {{ block.settings.icon_hover_color }};
      }

      .ai-icon-item-{{ ai_gen_id }}:hover .ai-icon-wrapper-{{ ai_gen_id }} svg {
        fill: {{ block.settings.icon_hover_color }};
        stroke: {{ block.settings.icon_hover_color }};
      }

      .ai-icon-item-{{ ai_gen_id }}:hover .ai-icon-wrapper-{{ ai_gen_id }} img {
        filter: {{ block.settings.image_hover_filter | default: 'none' }};
      }

      .ai-icon-title-{{ ai_gen_id }} {
        font-size: {{ block.settings.title_size }}px;
        font-weight: 600;
        margin: 0 0 {{ block.settings.title_spacing }}px;
        color: {{ block.settings.title_color }};
      }

      .ai-icon-item-{{ ai_gen_id }}:hover .ai-icon-title-{{ ai_gen_id }} {
        color: {{ block.settings.title_hover_color }};
      }

      .ai-icon-text-{{ ai_gen_id }} {
        font-size: {{ block.settings.text_size }}px;
        margin: 0;
        color: {{ block.settings.text_color }};
      }

      .ai-icon-item-{{ ai_gen_id }}:hover .ai-icon-text-{{ ai_gen_id }} {
        color: {{ block.settings.text_hover_color }};
      }

      @media screen and (max-width: 749px) {
        .ai-icon-row-container-{{ ai_gen_id }} {
          grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
        }
      }
{% endstyle %}

<icon-row-{{ ai_gen_id }} class="ai-icon-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-row-wrapper-{{ai_gen_id }}">
    <div class="ai-icon-row-container-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign title_key = 'icon_' | append: i | append: '_title'
          assign text_key = 'icon_' | append: i | append: '_text'
          assign link_key = 'icon_' | append: i | append: '_link'
          assign content_key = 'icon_' | append: i | append: '_content'

          assign title = block.settings[title_key]
          assign text = block.settings[text_key]
          assign link = block.settings[link_key]
          assign content = block.settings[content_key]
        %}

        {% if link != blank %}
          <a href="{{ link }}" class="ai-icon-item-{{ ai_gen_id }}">
        {% else %}
          <div class="ai-icon-item-{{ ai_gen_id }}">
        {% endif %}

        <div class="ai-icon-wrapper-{{ ai_gen_id }}">
          {% if content != blank %}
            {{ content }}
          {% else %}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
          {% endif %}
        </div>

        {% if title != blank %}
          <h3 class="ai-icon-title-{{ ai_gen_id }}">{{ title }}</h3>
        {% endif %}

        {% if text != blank %}
          <p class="ai-icon-text-{{ ai_gen_id }}">{{ text }}</p>
        {% endif %}

        {% if link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</icon-row-{{ ai_gen_id }}>

<script>
  (function() {
    class IconRow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('icon-row-{{ ai_gen_id }}', IconRow{{ ai_gen_id }});
  })();
</script>

