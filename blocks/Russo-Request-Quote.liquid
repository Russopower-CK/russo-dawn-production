{% schema %}
{
  "name": "Product Form Tab",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Product Form Tab",
      "category": "Product"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  .collapsible-tab {
    border-top: 1px solid #ddd;
    margin-top: 1rem;
  }
  .collapsible-tab summary {
    font-weight: bold;
    cursor: pointer;
    padding: 1rem;
    background: #f9f9f9;
  }
  .collapsible-tab details[open] summary {
    border-bottom: 1px solid #ddd;
  }
  .collapsible-tab .tab-content {
    padding: 1rem;
  }
{% endstylesheet %}

<div class="collapsible-tab">
  <details>
    <summary>More Info / Sign Up</summary>
    <div class="tab-content">
      {% for block in section.blocks %}
        {% render block %}
      {% endfor %}
    </div>
  </details>
</div>
